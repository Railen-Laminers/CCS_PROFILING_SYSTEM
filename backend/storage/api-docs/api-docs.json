{
  "openapi": "3.0.0",
  "info": {
    "title": "Profiling System API",
    "version": "1.0.0",
    "description": "API documentation for the Profiling System - manage users, courses, and events"
  },
  "servers": [
    {
      "url": "/api",
      "description": "API Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearer_token": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "UUID",
        "description": "Bearer token authentication"
      }
    }
  },
  "security": [{"bearer_token": []}],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "User login",
        "operationId": "login",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["identifier", "password"],
                "properties": {
                  "identifier": {"type": "string", "example": "2024001"},
                  "password": {"type": "string", "format": "password"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Login successful"},
          "401": {"description": "Invalid credentials"}
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Get current user",
        "operationId": "getMe",
        "responses": {"200": {"description": "User info"}}
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Authentication"],
        "summary": "User logout",
        "operationId": "logout",
        "responses": {"200": {"description": "Logout successful"}}
      }
    },
    "/users": {
      "get": {
        "tags": ["Users"],
        "summary": "List all users",
        "operationId": "listUsers",
        "responses": {"200": {"description": "Users list"}}
      },
      "post": {
        "tags": ["Users"],
        "summary": "Create user",
        "operationId": "createUser",
        "responses": {"201": {"description": "User created"}}
      }
    },
    "/users/{id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Get user",
        "operationId": "getUser",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {"200": {"description": "User details"}}
      },
      "put": {
        "tags": ["Users"],
        "summary": "Update user",
        "operationId": "updateUser",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "User updated"}}
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Delete user",
        "operationId": "deleteUser",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "User deleted"}}
      }
    },
    "/students": {
      "get": {
        "tags": ["Users"],
        "summary": "List students",
        "operationId": "getStudents",
        "responses": {"200": {"description": "Students list"}}
      }
    },
    "/faculty": {
      "get": {
        "tags": ["Users"],
        "summary": "List faculty",
        "operationId": "getFaculty",
        "responses": {"200": {"description": "Faculty list"}}
      }
    },
    "/courses": {
      "get": {
        "tags": ["Courses"],
        "summary": "List courses",
        "operationId": "listCourses",
        "responses": {"200": {"description": "Courses list"}}
      },
      "post": {
        "tags": ["Courses"],
        "summary": "Create course",
        "operationId": "createCourse",
        "responses": {"201": {"description": "Course created"}}
      }
    },
    "/courses/{id}": {
      "get": {
        "tags": ["Courses"],
        "summary": "Get course",
        "operationId": "getCourse",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {"200": {"description": "Course details"}}
      },
      "put": {
        "tags": ["Courses"],
        "summary": "Update course",
        "operationId": "updateCourse",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Course updated"}}
      },
      "delete": {
        "tags": ["Courses"],
        "summary": "Delete course",
        "operationId": "deleteCourse",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Course deleted"}}
      }
    },
    "/events": {
      "get": {
        "tags": ["Events"],
        "summary": "List events",
        "operationId": "listEvents",
        "responses": {"200": {"description": "Events list"}}
      },
      "post": {
        "tags": ["Events"],
        "summary": "Create event",
        "operationId": "createEvent",
        "responses": {"201": {"description": "Event created"}}
      }
    },
    "/events/{search}": {
      "get": {
        "tags": ["Events"],
        "summary": "Search events",
        "operationId": "searchEvents",
        "parameters": [{"name": "search", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {"200": {"description": "Event details"}}
      }
    },
    "/events/{id}": {
      "put": {
        "tags": ["Events"],
        "summary": "Update event",
        "operationId": "updateEvent",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Event updated"}}
      },
      "delete": {
        "tags": ["Events"],
        "summary": "Delete event",
        "operationId": "deleteEvent",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Event deleted"}}
      }
    }
  },
  "tags": [
    {"name": "Authentication"},
    {"name": "Users"},
    {"name": "Courses"},
    {"name": "Events"}
  ]
}